APP_NAME=Centrova
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://centrova.id

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=centrova
DB_USERNAME=root
DB_PASSWORD=

# ──────────────────────────────────────
# CACHE & PERFORMANCE
# ──────────────────────────────────────

# Cache/Queue/Session Driver — Redis sangat direkomendasikan
# Set ke "file" jika Redis belum tersedia di lingkungan saat ini
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Redis Configuration
REDIS_CLIENT=phpredis          # phpredis (recommended) | predis | mock
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0                     # Default database
REDIS_CACHE_DB=1               # Database khusus cache (terpisah dari session/queue)

# Laravel Page Speed — HTML minification & optimization
LARAVEL_PAGE_SPEED_ENABLE=true

# Laravel Octane (high‑performance application server)
# Aktifkan hanya jika infrastructure sudah siap
# OCTANE_SERVER=swoole          # swoole | roadrunner
# OCTANE_WORKERS=auto

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@centrova.id"
MAIL_FROM_NAME="${APP_NAME}"

# SEO Configuration
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_SITE_VERIFICATION=
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# Social Media Configuration
FACEBOOK_APP_ID=
FACEBOOK_PIXEL_ID=
TWITTER_SITE=@centrova_id
TWITTER_CREATOR=@centrova_id

# Performance Optimization
IMAGE_OPTIMIZATION_ENABLED=true
VITE_APP_COMPRESS_IMAGES=true

# Subdomain Configuration
USE_SUBDOMAINS=true
FALLBACK_ROUTES_ENABLED=true
LOCAL_SUBDOMAINS_ENABLED=false

# Security
BCRYPT_ROUNDS=12

# Broadcasting
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
# =============================================================================
# SUBDOMAIN & FALLBACK ROUTES CONFIGURATION
# =============================================================================

# Enable/disable subdomain routing
# Set to false if subdomains are not available (shared hosting, etc.)
USE_SUBDOMAINS=true

# Enable/disable fallback routes when subdomains fail
# Should be true for production environments
FALLBACK_ROUTES_ENABLED=true

# Enable subdomains in local development
# Most local environments don't support subdomains properly
LOCAL_SUBDOMAINS_ENABLED=false

# =============================================================================
# USAGE EXAMPLES:
# =============================================================================
# 
# Production with subdomains:
# USE_SUBDOMAINS=true
# FALLBACK_ROUTES_ENABLED=true
# LOCAL_SUBDOMAINS_ENABLED=false
#
# Production without subdomains (shared hosting):
# USE_SUBDOMAINS=false
# FALLBACK_ROUTES_ENABLED=true
# LOCAL_SUBDOMAINS_ENABLED=false
#
# Local development with subdomain support:
# USE_SUBDOMAINS=true
# FALLBACK_ROUTES_ENABLED=true
# LOCAL_SUBDOMAINS_ENABLED=true
#
# Local development without subdomain support:
# USE_SUBDOMAINS=false
# FALLBACK_ROUTES_ENABLED=true
# LOCAL_SUBDOMAINS_ENABLED=false
# =============================================================================

{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://centrova.id",
    "ASSET_URL": "https://centrova.id",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "database",
    "SESSION_SECURE_COOKIE": "true",
    "CACHE_DRIVER": "database",
    "FILESYSTEM_DISK": "local",
    "APP_STORAGE_PATH": "/tmp/laravel-storage",
    "APP_CONFIG_CACHE": "/tmp/laravel-storage/config.php",
    "APP_EVENTS_CACHE": "/tmp/laravel-storage/events.php",
    "APP_ROUTES_CACHE": "/tmp/laravel-storage/routes.php",
    "APP_SERVICES_CACHE": "/tmp/laravel-storage/services.php",
    "VIEW_COMPILED_PATH": "/tmp/laravel-storage/view"
  }
}

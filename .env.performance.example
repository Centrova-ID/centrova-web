##############################################
# PERFORMANCE OPTIMIZATION ENVIRONMENT
##############################################

# Cache Configuration
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Performance Settings
CACHE_STATIC_TTL=3600      # 1 hour for static pages
CACHE_DYNAMIC_TTL=300      # 5 minutes for dynamic pages
CACHE_API_TTL=60           # 1 minute for API responses
CACHE_FRAGMENT_TTL=900     # 15 minutes for fragments
CACHE_QUERY_TTL=600        # 10 minutes for queries

# Cache Pre-warming
CACHE_PRE_WARM=true

# HTTP/2 Server Push
HTTP2_PUSH_ENABLED=true

# Asset Optimization
ASSET_URL="${APP_URL}"

# Session Configuration (Redis for performance)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Performance Monitoring
DEBUGBAR_ENABLED=false     # Disable in production
TELESCOPE_ENABLED=false    # Enable only in staging/dev
